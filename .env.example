# Copy this file to .env and fill in your values
# Get credentials at: https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://172.21.155.49:5000/callback

# Generate a strong random string for session security
FLASK_SECRET_KEY=change-this-to-a-random-secret-key

# Supabase PostgreSQL (get from: supabase.com → Project Settings → Database → URI)
# Leave empty to disable persistence (app still works, just no history stored)
DATABASE_URL=postgresql://postgres:your_password@db.xxxx.supabase.co:5432/postgres
